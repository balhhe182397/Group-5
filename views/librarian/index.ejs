<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-primary mb-3">
                <i class="fas fa-user-tie me-2"></i>Librarian Dashboard
            </h2>
            <p class="text-muted">Manage book borrows and library operations</p>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-4">
            <div class="card stat-card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-subtitle mb-2">Total Books</h6>
                            <h3 class="card-title mb-0"><%= stats.totalBooks %></h3>
                        </div>
                        <i class="fas fa-books fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card stat-card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-subtitle mb-2">Active Borrows</h6>
                            <h3 class="card-title mb-0"><%= stats.activeBorrows %></h3>
                        </div>
                        <i class="fas fa-bookmark fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card stat-card bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-subtitle mb-2">Pending Requests</h6>
                            <h3 class="card-title mb-0"><%= stats.pendingRequests %></h3>
                        </div>
                        <i class="fas fa-clock fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card stat-card bg-danger text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-subtitle mb-2">Overdue Books</h6>
                            <h3 class="card-title mb-0"><%= stats.overdueBooks %></h3>
                        </div>
                        <i class="fas fa-exclamation-triangle fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Librarian Actions -->
    <div class="row">
        <!-- Borrow Management -->
        <div class="col-md-6 mb-4">
            <div class="card librarian-card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-bookmark me-2 text-success"></i>Borrow Management
                    </h5>
                    <p class="card-text text-muted">Manage book borrows and returns</p>
                    <div class="librarian-actions">
                        <a href="/librarian/borrows" class="btn btn-outline-success">
                            <i class="fas fa-list me-2"></i>View All Borrows
                        </a>
                        <a href="/librarian/borrows/pending" class="btn btn-outline-warning">
                            <i class="fas fa-clock me-2"></i>Pending Requests
                        </a>
                        <a href="/librarian/borrows/overdue" class="btn btn-outline-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>Overdue Books
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Payment Management -->
        <div class="col-md-6 mb-4">
            <div class="card librarian-card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-money-bill-wave me-2 text-danger"></i>Payment Management
                    </h5>
                    <p class="card-text text-muted">Manage fine payments and confirmations</p>
                    <div class="librarian-actions">
                        <a href="/librarian/payments" class="btn btn-outline-danger">
                            <i class="fas fa-list me-2"></i>View All Payments
                        </a>
                        <a href="/librarian/payments?status=pending" class="btn btn-outline-warning">
                            <i class="fas fa-clock me-2"></i>Pending Payments
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="col-md-6 mb-4">
            <div class="card librarian-card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-tasks me-2 text-info"></i>Quick Actions
                    </h5>
                    <p class="card-text text-muted">Common library operations</p>
                    <div class="librarian-actions">
                        <a href="/books" class="btn btn-outline-info">
                            <i class="fas fa-search me-2"></i>Search Books
                        </a>
                        <a href="/borrows" class="btn btn-outline-primary">
                            <i class="fas fa-bookmark me-2"></i>Borrow History
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Reports -->
        <div class="col-md-6 mb-4">
            <div class="card librarian-card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-chart-bar me-2 text-warning"></i>Reports
                    </h5>
                    <p class="card-text text-muted">View borrowing statistics</p>
                    <div class="librarian-actions">
                        <a href="/librarian/reports/borrows" class="btn btn-outline-warning">
                            <i class="fas fa-chart-line me-2"></i>Borrowing Reports
                        </a>
                        <a href="/librarian/reports/overdue" class="btn btn-outline-danger">
                            <i class="fas fa-chart-pie me-2"></i>Overdue Reports
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.stat-card {
    border: none;
    border-radius: 10px;
    transition: transform 0.2s;
}

.stat-card:hover {
    transform: translateY(-5px);
}

.librarian-card {
    border: none;
    border-radius: 10px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    transition: transform 0.2s;
}

.librarian-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
}

.librarian-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
}

.btn {
    border-radius: 6px;
    font-weight: 500;
    transition: all 0.3s ease;
}

.btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}

.opacity-50 {
    opacity: 0.5;
}
</style> 
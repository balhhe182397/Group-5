<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-primary mb-3">
                <i class="fas fa-tachometer-alt me-2"></i>Dashboard Cá Nhân
            </h2>
            <p class="text-muted">Tổng quan hoạt động của bạn tại thư viện</p>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-3 mb-4">
            <div class="card stat-card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-subtitle mb-2">Tổng sách đã mượn</h6>
                            <h3 class="card-title mb-0"><%= stats.totalBorrows %></h3>
                        </div>
                        <i class="fas fa-book fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card stat-card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-subtitle mb-2">Sách đang mượn</h6>
                            <h3 class="card-title mb-0"><%= stats.activeBorrows %></h3>
                        </div>
                        <i class="fas fa-book-reader fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card stat-card bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-subtitle mb-2">Tổng tiền phạt</h6>
                            <h3 class="card-title mb-0"><%= stats.totalFines.toLocaleString('vi-VN') %> VND</h3>
                        </div>
                        <i class="fas fa-coins fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card stat-card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-subtitle mb-2">Bình luận đã viết</h6>
                            <h3 class="card-title mb-0"><%= stats.totalComments %></h3>
                        </div>
                        <i class="fas fa-comments fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <a href="/borrows/my-borrows" class="btn btn-outline-primary me-2">
                <i class="fas fa-bookmark me-1"></i> Xem lịch sử mượn sách
            </a>
            <a href="/books" class="btn btn-outline-success me-2">
                <i class="fas fa-search me-1"></i> Tìm kiếm sách
            </a>
            <a href="/users/profile" class="btn btn-outline-info">
                <i class="fas fa-user me-1"></i> Thông tin cá nhân
            </a>
        </div>
    </div>
</div> 